# ===================================
# Food Donation Website - Environment Configuration
# ===================================
# Copy this file to .env and update the values for your environment
# ===================================

# ===================================
# Frontend Configuration
# ===================================
# API Base URL - Change this to your backend URL in production
# For Docker/Render deployment (all-in-one): use /api
# For Vercel + separate backend: use your backend URL
VITE_API_BASE_URL=/api

# ===================================
# Backend Configuration (Spring Boot)
# ===================================
# Server Port
PORT=8080

# Spring Profile (dev, prod)
SPRING_PROFILES_ACTIVE=prod

# ===================================
# Database Configuration (MySQL)
# ===================================
# For Development (Local MySQL)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/food_donation?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_mysql_password

# For Production (Render MySQL or Cloud MySQL)
# Replace with your production MySQL connection details
# SPRING_DATASOURCE_URL=jdbc:mysql://YOUR_DB_HOST:3306/food_donation_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
# SPRING_DATASOURCE_USERNAME=your_mysql_username
# SPRING_DATASOURCE_PASSWORD=your_mysql_password

# JPA/Hibernate Settings
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.MySQL8Dialect

# ===================================
# JWT Security Configuration
# ===================================
# IMPORTANT: Change this to a strong random string in production!
APP_JWT_SECRET=foodDonationSuperSecretKeyForJwtTokenGeneration2026
APP_JWT_EXPIRATION_MS=86400000

# CORS allow-list patterns (comma separated)
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://localhost:5173,http://localhost:8080,https://food-donation-website-amqz.onrender.com,https://food-donation-website-*.vercel.app

# ===================================
# Application Settings
# ===================================
# Application name
APP_NAME=Food Donation Website

# ===================================
# Optional: External Services
# ===================================
# Add any external service credentials here (e.g., email, storage, etc.)
# Example:
# SENDGRID_API_KEY=your_sendgrid_key
# AWS_S3_BUCKET=your_bucket_name
